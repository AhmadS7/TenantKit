{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(corepack:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Bash(bash:*)",
      "Bash(make:*)",
      "Bash(stripe:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(gh repo delete:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)",
      "Bash(dropdb:*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/secrets/**)",
      "Read(.env)"
    ],
    "ask": [
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker compose down --volumes:*)",
      "Bash(pnpm publish:*)",
      "Bash(gh repo delete:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Write|Edit|MultiEdit", "hooks": [".claude/hooks/pre-tool-use.sh"] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit", "hooks": [".claude/hooks/post-tool-use.sh"] }
    ],
    "UserPromptSubmit": [
      { "hooks": [".claude/hooks/user-prompt-submit.sh"] }
    ],
    "Stop": [
      { "hooks": [".claude/hooks/stop.sh"] }
    ]
  },
  "env": {
    "TENANTKIT_TS_CONFIG": "tsconfig.json",
    "TENANTKIT_FRONTEND_DIR": "frontend",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  }
}
