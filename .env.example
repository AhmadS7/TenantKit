# ----------------------------------------------------------------------------
# TenantKit backend environment.
# Copy to `.env` and fill in real values. Validated at boot by
# src/config/env.validation.ts — the app fails fast on missing/invalid vars.
# ----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000

# Auth — REQUIRED. Must be at least 32 characters. Generate a strong random
# value, e.g. `openssl rand -hex 32`. There is no fallback.
JWT_SECRET=replace_me_with_a_random_string_at_least_32_chars

# Database — REQUIRED (no fallbacks).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tenantkit

# Password for the least-privileged RLS role (tenantkit_app).
# REQUIRED in production; defaults to a placeholder in dev/test.
TENANT_DB_APP_PASSWORD=change_this_password

# Redis — used by cache, BullMQ queue and the throttler store.
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend origin used to build links in transactional emails (password reset).
FRONTEND_URL=http://localhost:3001

# CORS — comma-separated list of additional allowed origins. The localhost and
# *.tenantkit.app subdomains are always allowed. Example:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Stripe — optional. Absent or `change_me` => Mock Sandbox Mode.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENT_PRICE_ID=

# SMTP — optional. Absent SMTP_HOST => dev mail mode (emails are logged, not sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TenantKit <no-reply@tenantkit.app>
